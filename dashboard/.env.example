# GitHub Personal Access Token
# Create one at: https://github.com/settings/tokens
# Required scopes: repo, workflow
GITHUB_TOKEN=

# Your Clawtrl repository in owner/repo format
GITHUB_REPO=

# Wallet private key (Ethereum/Base). Keep secret!
# CLAWTRL_WALLET_PRIVATE_KEY=0x...
# AGENT_WALLET_PRIVATE_KEY=0x...

# Wallet confirmation PIN — required for destructive wallet actions (transfer, approve)
# CLAWTRL_WALLET_CONFIRM_PIN=

# Dashboard security — extra allowed hosts (comma-separated)
# CLAWTRL_DASHBOARD_ALLOWED_HOSTS=
# CLAWTRL_DASHBOARD_ALLOW_ANY_HOST=1

# Anthropic API key — enables Auto-Spec skill synthesis
# ANTHROPIC_API_KEY=
